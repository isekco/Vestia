<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vestia_background"
    tools:context=".ui.main.MainActivity">

    <LinearLayout
        android:id="@+id/topBanner"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/vestia_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/profileIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/profile_icon"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/vestia_white" />

        <TextView
            android:id="@+id/topTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/main_page_title"
            android:textColor="@color/vestia_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/expandIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/expand_icon"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/vestia_white" />

        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/settings_icon"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="@color/vestia_white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/portfolioCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/vestia_white"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:strokeColor="@color/vestia_border"
        app:strokeWidth="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBanner">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/portfolioCardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/portfolio_summary"
                android:textColor="@color/vestia_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/totalPortfolioValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/sample_total_value"
                android:textColor="@color/vestia_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:id="@+id/legendContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/legendUsd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_legend_dot_usd" />

                    <TextView
                        android:id="@+id/legendUsdText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="USD"
                        android:textColor="@color/vestia_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/legendUsdUnderline"
                        android:layout_width="28dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="@color/asset_usd"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/legendXau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_legend_dot_xau" />

                    <TextView
                        android:id="@+id/legendXauText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="XAU"
                        android:textColor="@color/vestia_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/legendXauUnderline"
                        android:layout_width="28dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="@color/asset_xau"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/legendGbp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_legend_dot_gbp" />

                    <TextView
                        android:id="@+id/legendGbpText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="GBP"
                        android:textColor="@color/vestia_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/legendGbpUnderline"
                        android:layout_width="28dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="@color/asset_gbp"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/legendEur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_legend_dot_eur" />

                    <TextView
                        android:id="@+id/legendEurText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="EUR"
                        android:textColor="@color/vestia_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/legendEurUnderline"
                        android:layout_width="28dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="@color/asset_eur"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/assetRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        tools:listitem="@layout/item_asset_summary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/portfolioCard" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addTransactionFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="@string/add_transaction"
        android:src="@android:drawable/ic_input_add"
        android:tint="@color/vestia_white"
        app:backgroundTint="@color/vestia_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>