<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vestia_background"
    tools:context=".ui.main.MainActivity">

    <LinearLayout
        android:id="@+id/topBanner"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/vestia_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/topTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/portfolio_summary"
            android:textColor="@color/vestia_white"
            android:textSize="@dimen/text_portfolio_summary_title"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/portfolioCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/vestia_white"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBanner"
        app:strokeColor="@color/vestia_border"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/portfolioCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/portfolio_summary"
                android:textColor="@color/vestia_text_secondary"
                android:textStyle="bold"
                android:textSize="@dimen/text_portfolio_summary_title"
                android:gravity="center"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_portfolio_summary_title_min"
                app:autoSizeMaxTextSize="@dimen/text_portfolio_summary_title_max"
                app:autoSizeStepGranularity="1sp" />

            <TextView
                android:id="@+id/totalPortfolioValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="none"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:text="@string/sample_total_value"
                android:textColor="@color/vestia_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/text_total_portfolio_value"
                android:gravity="center"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_total_portfolio_value_min"
                app:autoSizeMaxTextSize="@dimen/text_total_portfolio_value_max"
                app:autoSizeStepGranularity="1sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/assetRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/portfolioCard"
        tools:listitem="@layout/item_asset_summary" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addTransactionFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="@string/add_transaction"
        android:src="@android:drawable/ic_input_add"
        android:tint="@color/vestia_white"
        app:backgroundTint="@color/vestia_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>