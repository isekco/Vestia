<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Instrument Name -->

    <TextView
        android:id="@+id/instrumentNameText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="USD Cash"
        android:textSize="14sp"
        android:textColor="@color/vestia_text_secondary"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Quantity -->

    <TextView
        android:id="@+id/instrumentQuantityText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1200"
        android:textSize="14sp"
        android:textColor="@color/vestia_text_secondary"
        android:layout_marginEnd="10dp"/>

    <!-- Rate -->

    <TextView
        android:id="@+id/instrumentRateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="32.10"
        android:textSize="14sp"
        android:textColor="@color/vestia_text_secondary"
        android:layout_marginEnd="10dp"/>

    <!-- Total Value -->

    <TextView
        android:id="@+id/instrumentTotalValueText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₺38,520"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/vestia_text_primary"/>

</LinearLayout>