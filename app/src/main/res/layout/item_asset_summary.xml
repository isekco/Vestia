<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/assetCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/vestia_white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/vestia_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/assetColorIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_legend_dot_usd" />

            <TextView
                android:id="@+id/assetNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/asset_name"
                android:textColor="@color/vestia_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/text_asset_title"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_asset_title_min"
                app:autoSizeMaxTextSize="@dimen/text_asset_title_max"
                app:autoSizeStepGranularity="1sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/assetQuantityText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="---"
                android:textColor="@color/vestia_text_secondary"
                android:textSize="@dimen/text_asset_info"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_asset_info_min"
                app:autoSizeMaxTextSize="@dimen/text_asset_info_max"
                app:autoSizeStepGranularity="1sp" />

            <TextView
                android:id="@+id/assetRateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=" / "
                android:textColor="@color/vestia_text_secondary"
                android:textSize="@dimen/text_asset_info"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_asset_info_min"
                app:autoSizeMaxTextSize="@dimen/text_asset_info_max"
                app:autoSizeStepGranularity="1sp" />

            <TextView
                android:id="@+id/assetValueTlText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="₺392.500,00"
                android:textStyle="bold"
                android:textColor="@color/vestia_text_primary"
                android:textSize="@dimen/text_asset_info"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="@dimen/text_asset_info_min"
                app:autoSizeMaxTextSize="@dimen/text_asset_info_max"
                app:autoSizeStepGranularity="1sp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>