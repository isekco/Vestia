<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/assetCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/vestia_white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/vestia_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="10dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <View
                android:id="@+id/assetTypeIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_dot_cash" />

            <TextView
                android:id="@+id/assetTypeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/asset_type_name"
                android:textColor="@color/vestia_text_primary"
                android:textSize="@dimen/text_asset_type_title"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="@dimen/text_asset_type_title_max"
                app:autoSizeMinTextSize="@dimen/text_asset_type_title_min"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <TextView
                android:id="@+id/assetTotalValueText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:gravity="end"
                android:text="@string/empty_string"
                android:textColor="@color/vestia_text_primary"
                android:textSize="@dimen/text_asset_type_info"
                android:textStyle="bold"
                app:autoSizeMaxTextSize="@dimen/text_asset_type_info_max"
                app:autoSizeMinTextSize="@dimen/text_asset_type_info_min"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <ImageView
                android:id="@+id/expandIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="@string/expand_icon"
                android:src="@drawable/ic_expand_more" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/instrumentRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>